#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: auth-load <name>" >&2
  exit 1
fi

PROFILE_NAME="$1"
if [[ ! "$PROFILE_NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  echo "Error: profile name must contain only alphanumeric characters, dashes, and underscores" >&2
  exit 1
fi

# shellcheck source=_resolve-session
source "$(dirname "$0")/_resolve-session"

PROFILE="$_SKILL_DIR/.playwright-skill/auth/$PROFILE_NAME.json"
if [ ! -f "$PROFILE" ]; then
  echo "Error: Auth profile '$PROFILE_NAME' not found at $PROFILE" >&2
  echo "Available profiles:" >&2
  ls "$_SKILL_DIR/.playwright-skill/auth/"*.json 2>/dev/null | xargs -I{} basename {} .json >&2 || echo "  (none)" >&2
  exit 1
fi

playwright-cli $_SESSION_FLAG state-load "$PROFILE"
