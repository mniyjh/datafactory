#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: auth-save <name>" >&2
  exit 1
fi

PROFILE_NAME="$1"
if [[ ! "$PROFILE_NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  echo "Error: profile name must contain only alphanumeric characters, dashes, and underscores" >&2
  exit 1
fi

# shellcheck source=_resolve-session
source "$(dirname "$0")/_resolve-session"

mkdir -p "$_SKILL_DIR/.playwright-skill/auth"
playwright-cli $_SESSION_FLAG state-save "$_SKILL_DIR/.playwright-skill/auth/$PROFILE_NAME.json"
echo "Auth profile '$PROFILE_NAME' saved to $_SKILL_DIR/.playwright-skill/auth/$PROFILE_NAME.json"
