{
  "_说明": "============================================================",
  "_说明2": "数据工厂综合任务配置 — 使用全部 8 种组件",
  "_说明3": "组件清单: COMP_START / COMP_DB_QUERY / COMP_API_CALL / COMP_PYTHON_EXECUTOR / COMP_FILTER / COMP_BRANCH / COMP_SUB_TASK / COMP_END",
  "_说明4": "免费 API: https://jsonplaceholder.typicode.com/users (无需认证)",
  "_说明5": "============================================================",

  "mainTask": {
    "taskCode": "COMPREHENSIVE_DEMO",
    "taskName": "员工薪资综合分析",
    "description": "使用全部8种组件: START → DB查询员工 → API获取外部数据 → Python脚本增强分析 → FILTER过滤高薪 → BRANCH条件判断 → SUB_TASK子任务聚合 → END",
    "category": "综合演示",

    "dsl": {
      "schemaVersion": 3,
      "nodes": [
        {
          "id": "s1",
          "type": "START",
          "name": "开始",
          "label": "开始节点",
          "componentCode": "COMP_START",
          "componentId": 1,
          "position": {"x": 80, "y": 250},
          "fieldValues": {},
          "inputParams": [],
          "outputParams": []
        },

        {
          "id": "db1",
          "type": "DB",
          "name": "查询在职员工",
          "label": "DB-员工查询",
          "componentCode": "COMP_DB_QUERY",
          "componentId": 3,
          "position": {"x": 250, "y": 100},
          "fieldValues": {
            "sql": "SELECT id, emp_name, department, salary, hire_date FROM employee WHERE status = 1 ORDER BY salary DESC",
            "result_var": "dbEmployees"
          },
          "inputParams": [],
          "outputParams": [
            {"paramCode": "rows",    "paramName": "查询结果集",   "dataType": "JSON",   "paramSpace": "NODE"},
            {"paramCode": "rowCount","paramName": "结果行数",     "dataType": "NUMBER", "paramSpace": "NODE"}
          ]
        },

        {
          "id": "api1",
          "type": "API",
          "name": "获取外部用户",
          "label": "API-免费用户接口",
          "componentCode": "COMP_API_CALL",
          "componentId": 4,
          "position": {"x": 250, "y": 400},
          "fieldValues": {
            "url": "https://jsonplaceholder.typicode.com/users",
            "method": "GET",
            "result_var": "apiUsers"
          },
          "inputParams": [],
          "outputParams": [
            {"paramCode": "statusCode", "paramName": "HTTP状态码", "dataType": "NUMBER", "paramSpace": "NODE"},
            {"paramCode": "body",       "paramName": "响应体",     "dataType": "JSON",   "paramSpace": "NODE"}
          ]
        },

        {
          "id": "sc1",
          "type": "SCRIPT",
          "name": "Python数据分析",
          "label": "SCRIPT-综合处理",
          "componentCode": "COMP_PYTHON_EXECUTOR",
          "componentId": 5,
          "position": {"x": 480, "y": 250},
          "fieldValues": {
            "scriptCode": "comprehensive_analysis",
            "result_var": "mergedData"
          },
          "inputParams": [],
          "outputParams": [
            {"paramCode": "rows",     "paramName": "增强后的数据", "dataType": "JSON",   "paramSpace": "NODE"},
            {"paramCode": "rowCount", "paramName": "数据行数",     "dataType": "NUMBER", "paramSpace": "NODE"},
            {"paramCode": "stats",    "paramName": "统计分析结果", "dataType": "JSON",   "paramSpace": "NODE"},
            {"paramCode": "enriched", "paramName": "是否已增强",   "dataType": "BOOLEAN","paramSpace": "NODE"}
          ]
        },

        {
          "id": "f1",
          "type": "FILTER",
          "name": "过滤高薪员工",
          "label": "FILTER-薪资>12000",
          "componentCode": "COMP_FILTER",
          "componentId": 6,
          "position": {"x": 710, "y": 250},
          "fieldValues": {
            "filterMode": "EXPRESSION",
            "expression": "salary > 12000",
            "sourceNodeId": "sc1",
            "result_var": "highSalaryData"
          },
          "inputParams": [],
          "outputParams": [
            {"paramCode": "rows",     "paramName": "高薪员工列表",  "dataType": "JSON",   "paramSpace": "NODE"},
            {"paramCode": "rowCount", "paramName": "高薪员工数量",  "dataType": "NUMBER", "paramSpace": "NODE"}
          ]
        },

        {
          "id": "b1",
          "type": "BRANCH",
          "name": "高薪判断分支",
          "label": "BRANCH-条件判断",
          "componentCode": "COMP_BRANCH",
          "componentId": 7,
          "position": {"x": 940, "y": 250},
          "fieldValues": {
            "expression": "rowCount > 0",
            "trueBranch": "sub1",
            "falseBranch": "e1"
          },
          "inputParams": [],
          "outputParams": [
            {"paramCode": "conditionResult", "paramName": "条件判断结果", "dataType": "BOOLEAN","paramSpace": "NODE"},
            {"paramCode": "nextNodeId",      "paramName": "下一节点ID",   "dataType": "STRING", "paramSpace": "NODE"}
          ]
        },

        {
          "id": "sub1",
          "type": "COMMON_TASK",
          "name": "子任务调用",
          "label": "SUB_TASK-部门聚合",
          "componentCode": "COMP_SUB_TASK",
          "componentId": 8,
          "position": {"x": 1170, "y": 150},
          "fieldValues": {
            "subTaskId": "__CHILD_TASK_ID__",
            "result_var": "subTaskResult"
          },
          "inputParams": [
            {
              "paramCode": "parentTaskName",
              "paramName": "父任务名称",
              "dataType": "STRING",
              "paramSpace": "TASK",
              "sourceType": "CONST",
              "sourceValue": "员工薪资综合分析"
            },
            {
              "paramCode": "highSalaryCount",
              "paramName": "高薪员工数量",
              "dataType": "NUMBER",
              "paramSpace": "TASK",
              "sourceType": "UPSTREAM_OUTPUT",
              "sourceValue": {"nodeId": "f1", "paramCode": "rowCount"}
            }
          ],
          "outputParams": [
            {"paramCode": "rows",     "paramName": "部门聚合结果", "dataType": "JSON",   "paramSpace": "NODE"},
            {"paramCode": "rowCount", "paramName": "部门数量",     "dataType": "NUMBER", "paramSpace": "NODE"}
          ]
        },

        {
          "id": "e1",
          "type": "END",
          "name": "结束",
          "label": "输出最终结果",
          "componentCode": "COMP_END",
          "componentId": 2,
          "position": {"x": 1400, "y": 250},
          "fieldValues": {},
          "inputParams": [],
          "outputParams": []
        }
      ],

      "edges": [
        {"id": "e_s_db",  "source": {"nodeId": "s1"},   "target": {"nodeId": "db1"}},
        {"id": "e_s_api", "source": {"nodeId": "s1"},   "target": {"nodeId": "api1"}},
        {"id": "e_db_sc", "source": {"nodeId": "db1"},  "target": {"nodeId": "sc1"}},
        {"id": "e_api_sc","source": {"nodeId": "api1"}, "target": {"nodeId": "sc1"}},
        {"id": "e_sc_f",  "source": {"nodeId": "sc1"},  "target": {"nodeId": "f1"}},
        {"id": "e_f_b",   "source": {"nodeId": "f1"},   "target": {"nodeId": "b1"}},
        {"id": "e_b_sub", "source": {"nodeId": "b1"},   "target": {"nodeId": "sub1"}},
        {"id": "e_b_end", "source": {"nodeId": "b1"},   "target": {"nodeId": "e1"}},
        {"id": "e_sub_e", "source": {"nodeId": "sub1"}, "target": {"nodeId": "e1"}}
      ],

      "viewport": {"scale": 0.65, "pan": {"x": 0, "y": 0}}
    }
  },

  "subTask": {
    "taskCode": "COMPREHENSIVE_SUB",
    "taskName": "部门聚合分析(子任务)",
    "description": "被主任务的 COMP_SUB_TASK 组件调用，按部门分组统计薪资",

    "dsl": {
      "schemaVersion": 3,
      "nodes": [
        {
          "id": "cs1",
          "type": "START",
          "name": "子任务开始",
          "label": "接收父任务参数",
          "componentCode": "COMP_START",
          "componentId": 1,
          "position": {"x": 80, "y": 150},
          "fieldValues": {},
          "inputParams": [
            {
              "paramCode": "parentTaskName",
              "paramName": "父任务名称",
              "dataType": "STRING",
              "paramSpace": "TASK",
              "sourceType": "CONST",
              "sourceValue": ""
            },
            {
              "paramCode": "highSalaryCount",
              "paramName": "高薪员工数量",
              "dataType": "NUMBER",
              "paramSpace": "TASK",
              "sourceType": "CONST",
              "sourceValue": "0"
            }
          ],
          "outputParams": []
        },

        {
          "id": "cdb1",
          "type": "DB",
          "name": "部门薪资聚合",
          "label": "DB-分组统计",
          "componentCode": "COMP_DB_QUERY",
          "componentId": 3,
          "position": {"x": 280, "y": 150},
          "fieldValues": {
            "sql": "SELECT department AS dept_name, COUNT(*) AS emp_count, ROUND(AVG(salary),2) AS avg_salary, MAX(salary) AS max_salary, MIN(salary) AS min_salary FROM employee WHERE status = 1 GROUP BY department ORDER BY avg_salary DESC",
            "result_var": "deptAggregation"
          },
          "inputParams": [],
          "outputParams": [
            {"paramCode": "rows",     "paramName": "部门统计结果", "dataType": "JSON",   "paramSpace": "NODE"},
            {"paramCode": "rowCount", "paramName": "部门数量",     "dataType": "NUMBER", "paramSpace": "NODE"}
          ]
        },

        {
          "id": "ce1",
          "type": "END",
          "name": "子任务结束",
          "label": "返回聚合结果",
          "componentCode": "COMP_END",
          "componentId": 2,
          "position": {"x": 480, "y": 150},
          "fieldValues": {},
          "inputParams": [],
          "outputParams": [
            {"paramCode": "deptAggregation", "paramName": "部门聚合数据", "dataType": "JSON", "paramSpace": "NODE"}
          ]
        }
      ],

      "edges": [
        {"id": "ce_s_db", "source": {"nodeId": "cs1"},  "target": {"nodeId": "cdb1"}},
        {"id": "ce_db_e", "source": {"nodeId": "cdb1"}, "target": {"nodeId": "ce1"}}
      ],

      "viewport": {"scale": 1, "pan": {"x": 0, "y": 0}}
    }
  },

  "组件使用对照表": {
    "COMP_START (开始节点)": {
      "nodeId": "s1",
      "作用": "任务入口，可接收外部触发参数",
      "入参": "无（或通过 API 触发时传入的参数）",
      "出参": "透传触发参数给下游"
    },
    "COMP_DB_QUERY (数据库查询)": {
      "nodeId": "db1",
      "作用": "从 employee 表查询在职员工数据",
      "fieldValues入参": {"sql": "SELECT id, emp_name, department, salary, hire_date FROM employee WHERE status = 1 ORDER BY salary DESC"},
      "出参": {"rows": "员工数据列表", "rowCount": "员工数量"}
    },
    "COMP_API_CALL (接口调用)": {
      "nodeId": "api1",
      "作用": "调用免费 API 获取外部用户数据用于增强",
      "fieldValues入参": {"url": "https://jsonplaceholder.typicode.com/users", "method": "GET"},
      "出参": {"statusCode": "200", "body": "10条用户JSON数据"}
    },
    "COMP_PYTHON_EXECUTOR (PYTHON执行器)": {
      "nodeId": "sc1",
      "作用": "Python脚本合并DB+API数据，计算统计指标",
      "入参": "stdin JSON: {dbEmployees: {rows, rowCount}, apiUsers: {statusCode, body}}",
      "出参": {"rows": "增强后的员工数据(含external_name/email/company/city)", "rowCount": 7, "stats": {"avg_salary": 15142.86, "max_salary": 22000, "min_salary": 11000, "high_salary_count": 5, "high_salary_ratio": 0.7143}, "enriched": true}
    },
    "COMP_FILTER (数据过滤)": {
      "nodeId": "f1",
      "作用": "通过Aviator表达式过滤薪资>12000的高薪员工",
      "fieldValues入参": {"filterMode": "EXPRESSION", "expression": "salary > 12000", "sourceNodeId": "sc1"},
      "出参": {"rows": "5条高薪员工数据", "rowCount": 5}
    },
    "COMP_BRANCH (条件分支)": {
      "nodeId": "b1",
      "作用": "判断高薪员工是否存在，决定后续路径",
      "fieldValues入参": {"expression": "rowCount > 0", "trueBranch": "sub1", "falseBranch": "e1"},
      "出参": {"conditionResult": true, "nextNodeId": "sub1"}
    },
    "COMP_SUB_TASK (子任务调用)": {
      "nodeId": "sub1",
      "作用": "调用子任务进行部门级别的聚合分析",
      "fieldValues入参": {"subTaskId": "<子任务数据库ID>"},
      "inputParams入参": {"parentTaskName": "员工薪资综合分析", "highSalaryCount": "来自f1.rowCount"},
      "出参": "子任务END节点的所有输出"
    },
    "COMP_END (结束节点)": {
      "nodeId": "e1",
      "作用": "汇总所有上游输出并作为最终结果返回",
      "入参": "上游所有节点的输出",
      "出参": "最终执行结果(JSON)"
    }
  },

  "数据流转图": {
    "描述": "START 同时触发 DB_QUERY 和 API_CALL 两个并行分支，在 SCRIPT 处汇聚合并",
    "流程": [
      "① START(s1) ─┬─→ DB_QUERY(db1) ──→ 查询7条在职员工",
      "              │                         ↓ (result_var: dbEmployees)",
      "              └─→ API_CALL(api1) ──→ 获取10条外部用户",
      "                                        ↓ (result_var: apiUsers)",
      "② SCRIPT(sc1) ← dbEmployees + apiUsers ─→ Python合并增强，计算统计",
      "                                              ↓ (result_var: mergedData)",
      "③ FILTER(f1) ← mergedData ─→ Aviator表达式: salary > 12000",
      "                                ↓ 过滤出5条高薪 (result_var: highSalaryData)",
      "④ BRANCH(b1) ← rowCount=5 ─→ 表达式: rowCount > 0 → true → sub1",
      "                                ↓ (如果是false则直接跳到END)",
      "⑤ SUB_TASK(sub1) ─→ 调用子任务: 按部门GROUP BY聚合薪资",
      "                                ↓ (result_var: subTaskResult)",
      "⑥ END(e1) ← 汇总所有输出 ─→ 返回完整JSON结果"
    ]
  },

  "部署步骤": {
    "step1_数据库初始化": {
      "描述": "在本地MySQL执行数据库初始化脚本",
      "命令": "mysql -u root -p < demo/init_comprehensive_demo.sql"
    },
    "step2_Python脚本注册": {
      "描述": "在数据工厂后台 → 脚本管理 → 新增脚本",
      "配置": {
        "scriptCode": "comprehensive_analysis",
        "scriptName": "综合数据分析脚本",
        "scriptType": "PYTHON",
        "scriptContent": "demo/comprehensive_analysis.py 的文件内容",
        "timeout": 60,
        "interpreterPath": "python"
      }
    },
    "step3_创建子任务": {
      "描述": "在数据工厂后台创建子任务(部门聚合分析)并发布",
      "API": "POST /task-dsl/version",
      "请求体": {
        "taskId": "<子任务ID>",
        "environment": "PROD",
        "version": "v1",
        "dslContent": "<subTask.dsl 的 JSON 字符串>"
      }
    },
    "step4_创建主任务": {
      "描述": "创建主任务，将 subTaskId 替换为实际子任务数据库ID",
      "API": "POST /task-dsl/version",
      "请求体": {
        "taskId": "<主任务ID>",
        "environment": "PROD",
        "version": "v1",
        "dslContent": "<mainTask.dsl 的 JSON 字符串(替换 __CHILD_TASK_ID__)>"
      }
    },
    "step5_发布并执行": {
      "描述": "发布版本 → 设为当前版本 → 执行任务 → 查看结果",
      "API_sequence": [
        "POST /task-dsl/version/{dslId}/publish",
        "POST /task-dsl/version/{dslId}/current",
        "POST /tasks/{taskId}/execute  (body: {versionId: dslId})",
        "GET /executor/log/detail/{executionId}  → 查看整体结果",
        "GET /executor/log/nodes/{executionId}   → 查看各节点状态"
      ]
    }
  }
}
