{
  "title": "DataFactory 监控面板",
  "panels": [
    {
      "title": "任务执行 QPS",
      "targets": [{ "expr": "rate(datafactory_executions_total[1m])" }]
    },
    {
      "title": "执行成功率",
      "targets": [{ "expr": "rate(datafactory_executions_success[5m]) / rate(datafactory_executions_total[5m])" }]
    },
    {
      "title": "执行耗时 P50/P90/P99",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(datafactory_execution_duration_bucket[5m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.90, rate(datafactory_execution_duration_bucket[5m]))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.99, rate(datafactory_execution_duration_bucket[5m]))", "legendFormat": "P99" }
      ]
    },
    {
      "title": "JVM 堆内存",
      "targets": [{ "expr": "jvm_memory_used_bytes{area=\"heap\"}" }]
    },
    {
      "title": "HikariCP 连接池活跃连接",
      "targets": [{ "expr": "hikaricp_connections_active" }]
    },
    {
      "title": "GC 暂停时间",
      "targets": [{ "expr": "rate(jvm_gc_pause_seconds_sum[1m])" }]
    }
  ]
}
