{
  "title": "DataFactory",
  "panels": [
    {
      "title": "Task Executions QPS",
      "targets": [{ "expr": "rate(datafactory_executions_total[1m])", "legendFormat": "QPS" }],
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 }
    },
    {
      "title": "Success Rate",
      "targets": [{ "expr": "rate(datafactory_executions_success[5m]) / rate(datafactory_executions_total[5m])", "legendFormat": "Rate" }],
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 }
    },
    {
      "title": "Execution Duration",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(datafactory_execution_duration_seconds_bucket[5m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.90, rate(datafactory_execution_duration_seconds_bucket[5m]))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.99, rate(datafactory_execution_duration_seconds_bucket[5m]))", "legendFormat": "P99" }
      ],
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 }
    },
    {
      "title": "JVM Heap Memory (MB)",
      "targets": [{ "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1048576", "legendFormat": "{{instance}}" }],
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 }
    },
    {
      "title": "HikariCP Active Connections",
      "targets": [{ "expr": "hikaricp_connections_active", "legendFormat": "{{instance}}" }],
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 }
    },
    {
      "title": "GC Pause (sec/s)",
      "targets": [{ "expr": "rate(jvm_gc_pause_seconds_sum[1m])", "legendFormat": "{{instance}}" }],
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 7 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39
}
